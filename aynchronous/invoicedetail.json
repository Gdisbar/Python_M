{
  "table_name": "INVOICEDETAIL",

  "oracle": {
    "group_by_column": "SOURCEDETAILID1",
    "base_query":      "SELECT * FROM CEX01_OWN.INVOICEDETAIL",
    "where_clause":    "SOURCEDETAILID1 IN ({SOURCE_NUMBERS})"
  },

  "postgres": {
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT * FROM sba_own.invoicedetail",
    "where_clause":    "sourcenumber IN ({SOURCE_NUMBERS})"
  },

  "column_mapping": {
    "INVOICEID":            { "pg_type": "int8",           "ora_type": "NUMBER" },
    "INVOICEDETAILID":      { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SALESTRANID":          { "pg_type": "numeric",        "ora_type": "NUMBER" },
    "SALESTRANDETAILID":    { "oracle_col": "SALESTRANLINEITEMID", "pg_type": "numeric", "ora_type": "NUMBER" },
    "SOURCESYSTEMID":       { "pg_type": "int4",           "ora_type": "NUMBER" },
    "SOURCENUMBER":         { "oracle_col": "SOURCEDETAILID1", "skip_compare": true },
    "ODLINK":               { "oracle_col": "SOURCEDETAILID2" },
    "ODSHP":                { "oracle_col": "SOURCEDETAILID3" },
    "ODSEQ":                { "oracle_col": "SOURCEDETAILID4" },
    "ODSSQ":                { "oracle_col": "SOURCEDETAILID5" },
    "ODAJS":                { "oracle_col": "SOURCEDETAILID6" },
    "SOURCEINSERTDATE":     { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEINSERTUSERID":   { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "SOURCEUPDATEDATE":     { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEUPDATEUSERID":   { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "INSERTDATE":           { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UPDATEDATE":           { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UNITPRICE":            { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "QUANTITYSHIPPED":      { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "TOTALLINECHARGES":     { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "OTHERCHARGES":         { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "TRANQUANTITY":         { "oracle_col": "TRANQUANTITY", "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "UNITOFMEASURE":        { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "PRODUCTSKU":           { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "PRODUCTCLASS":         { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "POSTINGCOST":          { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "POSTINGSKU":           { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "CASHPOSTINGDATE":      { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "INVPOSTINGDATE":       { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "FINANCIALTRANSDATE":   { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "EXTENDEDPRICE":        { "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" }
  }
}