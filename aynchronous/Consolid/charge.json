{
  "table_name": "CHARGE",

  "oracle": {
    "match_key":       "SALESTRANCHARGEID",
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT s.SALESTRANID, s.SALESTRANCHARGEID, SUBSTR(s.SOURCEHEADERKEY, 1, INSTR(s.SOURCEHEADERKEY, '.') - 1) AS SOURCENUMBER, SUBSTR(s.SOURCEHEADERKEY, INSTR(s.SOURCEHEADERKEY, '.') + 1) AS OHLINK, s.SOURCEINSERTDATE, s.SOURCEINSERTUSERID, s.SOURCESYSTEMID, s.SOURCEUPDATEDATE, s.SOURCEUPDATEUSERID, s.INSERTDATE, s.UPDATEDATE, s.TRANCHARGETYPE, s.TRANCHARGECATEGORY, s.TRANCHARGENAME, s.TRANCHARGEDESC, s.TRANCHARGEAMOUNT, s.CHARGETAXCODETYPE FROM CEX01_OWN.SALESTRANCHARGE s",
    "where_clause":    "SUBSTR(s.SOURCEHEADERKEY, 1, INSTR(s.SOURCEHEADERKEY, '.') - 1) IN ({SOURCE_NUMBERS})"
  },

  "postgres": {
    "match_key":       "CHARGEID",
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT * FROM sba_own.charge",
    "where_clause":    "sourcenumber IN ({SOURCE_NUMBERS})"
  },

  "column_mapping": {
    "SALESTRANID":        { "oracle_col": "SALESTRANID",        "pg_type": "int8",           "ora_type": "NUMBER" },
    "CHARGEID":           { "oracle_col": "SALESTRANCHARGEID",  "pg_type": "int8",           "ora_type": "NUMBER" },
    "SOURCENUMBER":       { "oracle_col": "SOURCENUMBER",                                     "skip_compare": true },
    "OHLINK":             { "oracle_col": "OHLINK",                                           "derived_in_oracle": true },
    "SOURCEINSERTDATE":   { "oracle_col": "SOURCEINSERTDATE",   "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEINSERTUSERID": { "oracle_col": "SOURCEINSERTUSERID" },
    "SOURCESYSTEMID":     { "oracle_col": "SOURCESYSTEMID",     "pg_type": "int4",           "ora_type": "NUMBER" },
    "SOURCEUPDATEDATE":   { "oracle_col": "SOURCEUPDATEDATE",   "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEUPDATEUSERID": { "oracle_col": "SOURCEUPDATEUSERID" },
    "INSERTDATE":         { "oracle_col": "INSERTDATE",         "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UPDATEDATE":         { "oracle_col": "UPDATEDATE",         "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "TRANCHARGETYPE":     { "oracle_col": "TRANCHARGETYPE" },
    "TRANCHARGECATEGORY": { "oracle_col": "TRANCHARGECATEGORY" },
    "TRANCHARGENAME":     { "oracle_col": "TRANCHARGENAME" },
    "TRANCHARGEDESC":     { "oracle_col": "TRANCHARGEDESC" },
    "TRANCHARGEAMOUNT":   { "oracle_col": "TRANCHARGEAMOUNT",   "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" },
    "CHARGETAXCODETYPE":  { "oracle_col": "CHARGETAXCODETYPE" }
  }
}