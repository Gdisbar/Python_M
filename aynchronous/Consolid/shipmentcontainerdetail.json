{
  "table_name": "SHIPMENTCONTAINERDETAIL",

  "oracle": {
    "group_by_column": "SOURCEDETAILID1",
    "base_query":      "SELECT * FROM CEX01_OWN.SHIPMENTCONTAINERDETAIL",
    "where_clause":    "SOURCEDETAILID1 IN ({SOURCE_NUMBERS})"
  },

  "postgres": {
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT * FROM sba_own.shipmentcontainerdetail",
    "where_clause":    "sourcenumber IN ({SOURCE_NUMBERS})"
  },

  "column_mapping": {
    "SHIPMENTCONTAINERID":       { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SHIPMENTCONTAINERDETAILID": { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SHIPMENTID":                { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SHIPMENTLINEID":            { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SALESTRANID":               { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SALESTRANDETAILID":         { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SOURCENUMBER":              { "oracle_col": "SOURCEDETAILID1", "pg_type": "varchar(50)",  "skip_compare": true },
    "OALINK":                    { "oracle_col": "SOURCEDETAILID2", "pg_type": "varchar(100)", "derived_in_oracle": true },
    "OASHP":                     { "oracle_col": "SOURCEDETAILID3", "pg_type": "varchar(100)", "derived_in_oracle": true },
    "OABOX":                     { "oracle_col": "SOURCEDETAILID4", "pg_type": "varchar(100)", "derived_in_oracle": true },
    "OASEQ":                     { "oracle_col": "SOURCEDETAILID5", "pg_type": "varchar(100)", "derived_in_oracle": true },
    "SOURCEINSERTDATE":          { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEUPDATEDATE":          { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEINSERTUSERID":        { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "SOURCEUPDATEUSERID":        { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "INSERTDATE":                { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UPDATEDATE":                { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEPRODUCTKEY":          { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "CONTAINERPRODUCTNAME":      { "pg_type": "varchar(100)",   "ora_type": "VARCHAR2(100)" },
    "CONTAINERQUANTITY":         { "pg_type": "int4",           "ora_type": "NUMBER" },
    "SOURCESYSTEMID":            { "pg_type": "int4",           "ora_type": "NUMBER" }
  }
}