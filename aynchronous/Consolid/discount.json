{
  "table_name": "DISCOUNT",

  "oracle": {
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT s.SALESTRANID, s.SALESTRANDISCOUNTID, SUBSTR(s.SOURCEHEADERKEY, 1, INSTR(s.SOURCEHEADERKEY, '.') - 1) AS SOURCENUMBER, SUBSTR(s.SOURCEHEADERKEY, INSTR(s.SOURCEHEADERKEY, '.') + 1) AS OHLINK, s.SOURCEINSERTDATE, s.SOURCEINSERTUSERID, s.SOURCESYSTEMID, s.SOURCEUPDATEDATE, s.SOURCEUPDATEUSERID, s.INSERTDATE, s.UPDATEDATE, s.TRANDISCOUNTTYPE, s.TRANDISCOUNTDESCRIPTION, s.TRANDISCOUNTTOTALAMOUNT FROM CEX01_OWN.SALESTRANDISCOUNT s",
    "where_clause":    "SUBSTR(s.SOURCEHEADERKEY, 1, INSTR(s.SOURCEHEADERKEY, '.') - 1) IN ({SOURCE_NUMBERS})"
  },

  "postgres": {
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT * FROM sba_own.discount",
    "where_clause":    "sourcenumber IN ({SOURCE_NUMBERS})"
  },

  "column_mapping": {
    "SALESTRANID":             { "oracle_col": "SALESTRANID",             "pg_type": "int8",           "ora_type": "NUMBER" },
    "DISCOUNTID":              { "oracle_col": "SALESTRANDISCOUNTID",     "pg_type": "int8",           "ora_type": "NUMBER" },
    "SOURCENUMBER":            { "oracle_col": "SOURCENUMBER",                                         "skip_compare": true },
    "OHLINK":                  { "oracle_col": "OHLINK",                                               "derived_in_oracle": true },
    "SOURCEINSERTDATE":        { "oracle_col": "SOURCEINSERTDATE",        "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEINSERTUSERID":      { "oracle_col": "SOURCEINSERTUSERID" },
    "SOURCESYSTEMID":          { "oracle_col": "SOURCESYSTEMID",          "pg_type": "int4",           "ora_type": "NUMBER" },
    "SOURCEUPDATEDATE":        { "oracle_col": "SOURCEUPDATEDATE",        "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEUPDATEUSERID":      { "oracle_col": "SOURCEUPDATEUSERID" },
    "INSERTDATE":              { "oracle_col": "INSERTDATE",              "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UPDATEDATE":              { "oracle_col": "UPDATEDATE",              "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "TRANDISCOUNTTYPE":        { "oracle_col": "TRANDISCOUNTTYPE" },
    "TRANDISCOUNTDESCRIPTION": { "oracle_col": "TRANDISCOUNTDESCRIPTION" },
    "TRANDISCOUNTTOTALAMOUNT": { "oracle_col": "TRANDISCOUNTTOTALAMOUNT", "pg_type": "numeric(19, 6)", "ora_type": "NUMBER(19,6)" }
  }
}