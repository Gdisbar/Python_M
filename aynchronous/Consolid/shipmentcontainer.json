{
  "table_name": "SHIPMENTCONTAINER",

  "oracle": {
    "group_by_column": "SOURCEHEADERID1",
    "base_query":      "SELECT * FROM CEX01_OWN.SHIPMENTCONTAINER",
    "where_clause":    "SOURCEHEADERID1 IN ({SOURCE_NUMBERS})"
  },

  "postgres": {
    "group_by_column": "SOURCENUMBER",
    "base_query":      "SELECT * FROM sba_own.shipmentcontainer",
    "where_clause":    "sourcenumber IN ({SOURCE_NUMBERS})"
  },

  "column_mapping": {
    "SHIPMENTCONTAINERID":   { "pg_type": "int8",           "ora_type": "NUMBER" },
    "SHIPMENTID":            { "pg_type": "numeric",        "ora_type": "NUMBER" },
    "SALESTRANID":           { "pg_type": "numeric",        "ora_type": "NUMBER" },
    "SOURCENUMBER":          { "oracle_col": "SOURCEHEADERID1", "skip_compare": true },
    "OBLINK":                { "oracle_col": "SOURCEHEADERID2" },
    "OBSHP":                 { "oracle_col": "SOURCEHEADERID3" },
    "OBBOX":                 { "oracle_col": "SOURCEHEADERID4" },
    "SOURCEINSERTDATE":      { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEUPDATEDATE":      { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "SOURCEINSERTUSERID":    { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "SOURCEUPDATEUSERID":    { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "INSERTDATE":            { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "UPDATEDATE":            { "pg_type": "timestamp(0)",   "ora_type": "DATE" },
    "CONTAINERNUMBER":       { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "CONTAINERSEQUENCENUMBER":{ "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "CONTAINMENTSHIPDATE":   { "oracle_col": "CONTAINERSHIPDATE", "pg_type": "timestamp(0)", "ora_type": "DATE" },
    "CARRIERID":             { "pg_type": "varchar(10)",    "ora_type": "VARCHAR2(10)" },
    "HUBCARRIER":            { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "SHIPVIA":               { "pg_type": "varchar(50)",    "ora_type": "VARCHAR2(50)" },
    "CONTAINERSTATUS":       { "pg_type": "varchar(100)",   "ora_type": "VARCHAR2(100)" },
    "SOURCESYSTEMID":        { "pg_type": "int4",           "ora_type": "NUMBER" }
  }
}